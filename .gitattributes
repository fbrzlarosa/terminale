* text=auto eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary

# Source: always LF
*.rs   text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.wgsl text eol=lf
*.sh   text eol=lf

# Windows-only
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf
